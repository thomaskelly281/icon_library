{
  "name": "blok-icons-workspace",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "generate": "tsx scripts/generate-icons.ts",
    "generate:force": "tsx scripts/generate-icons.ts --force",
    "icons:build": "tsx scripts/ensure-icons-built.ts",
    "pack:icons": "pnpm icons:build && pnpm --filter @blok/icons pack --pack-destination dist-packages",
    "dev": "tsx scripts/ensure-icons-built.ts && pnpm --filter app dev",
    "build": "tsx scripts/ensure-icons-built.ts && pnpm --filter app build",
    "vercel-build": "tsx scripts/ensure-icons-built.ts && pnpm --filter app build && tsx scripts/sync-next-output.ts",
    "start": "pnpm --filter app start",
    "lint": "pnpm --filter app lint",
    "typecheck": "pnpm --filter app typecheck"
  },
  "dependencies": {
    "@mdi/react": "^1.6.1",
    "@blok/icons": "workspace:*",
    "@tanstack/react-virtual": "^3.13.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "^15.5.3",
    "radix-ui": "^1.6.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "svgo": "^3.3.2",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
